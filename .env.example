# App
APP_ENV=development
LOG_LEVEL=debug
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://aria:aria@localhost:5432/aria

# Weaviate
WEAVIATE_URL=http://localhost:8080

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM — set one provider + its key.
#
# LOCAL TESTING (free, no credits): run Ollama on the host and use a small model
# to validate the pipeline before spending tokens.
#   ollama pull gemma3:4b
#   LLM_PROVIDER=ollama
# Judge the *plumbing* on gemma3:4b, not Gia's warmth — persona/voice quality is
# tuned later on GPT-4o / Claude. Swapping providers is env-only (no code change).
#
# DEMO / TUNING: LLM_PROVIDER=openai (gpt-4o) or anthropic (claude).
LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# From the host use localhost; from the api Docker container use host.docker.internal:
#   OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# Where the browser is sent after a successful Spotify sign-in. Must match the
# frontend origin (Next.js dev server defaults to :3000).
FRONTEND_URL=http://localhost:3000

# Spotify — OAuth credentials from developer.spotify.com
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/auth/spotify/callback
SPOTIFY_MCP_URL=http://localhost:3001
# Path to the built marcelmarais/spotify-mcp-server entrypoint. When set, the
# app spawns it over MCP stdio (real search + playback). Set up:
#   git clone https://github.com/marcelmarais/spotify-mcp-server && cd it
#   npm install && npm run build
#   create spotify-config.json (clientId/secret + redirectUri 127.0.0.1:8888/callback)
#   add that redirect URI in the Spotify dashboard, then: npm run auth
# Leave empty to run without live Spotify (features degrade gracefully).
SPOTIFY_MCP_SERVER_PATH=
SPOTIFY_MCP_COMMAND=node

# TTS — Kokoro locally (free), switch to ElevenLabs for voice tuning + recording.
# Kokoro needs the optional package: uv sync --extra local-tts
TTS_PROVIDER=kokoro
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Brave Search
BRAVE_API_KEY=

# Weather (Open-Meteo — no API key needed). Powers context-aware music picks.
# Set false to use a deterministic mock (offline). Defaults are Lagos.
WEATHER_ENABLED=true
WEATHER_DEFAULT_LAT=6.5244
WEATHER_DEFAULT_LON=3.3792
WEATHER_DEFAULT_LABEL=Lagos

# Langfuse tracing (SDK v4) — omit both keys to disable tracing in dev.
# Keys: Langfuse UI → Settings → API Keys. Host: EU https://cloud.langfuse.com,
# US https://us.cloud.langfuse.com, or your self-hosted URL.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Retrieval (RAG hardening)
# Hybrid search blends BM25 keyword + dense vector; alpha weights them
# (1.0 = pure vector, 0.0 = pure keyword, 0.5 = balanced).
HYBRID_ENABLED=true
RETRIEVAL_ALPHA=0.5
RETRIEVAL_K_PREFERENCES=8
RETRIEVAL_K_MOOD=3
RETRIEVAL_K_EPISODES=3
# Redis retrieval cache TTL in seconds (0 disables caching).
RETRIEVAL_CACHE_TTL=60
# Cross-encoder rerank — OFF by default to protect the voice latency budget.
# Turn on for Celery/eval or to demo the recall gain.
RERANK_ENABLED=false
RERANK_MODEL=BAAI/bge-reranker-base
RERANK_CANDIDATE_MULTIPLIER=3
# Multi-agent synthesis: merge several agents' outputs into one reply via an
# LLM pass. OFF by default (single-agent turns need no merge).
SYNTHESIS_ENABLED=false

# Tool resilience (timeout + circuit breaker for Spotify / Brave)
TOOL_TIMEOUT_S=8
TOOL_CIRCUIT_THRESHOLD=5
TOOL_CIRCUIT_COOLDOWN_S=30
