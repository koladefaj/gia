# App
APP_ENV=development
LOG_LEVEL=debug
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://aria:aria@localhost:5432/aria

# Weaviate
WEAVIATE_URL=http://localhost:8080

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM — set one provider + its key
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Spotify — OAuth credentials from developer.spotify.com
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/auth/spotify/callback
# URL of the spotify-mcp docker service (supergateway HTTP endpoint)
SPOTIFY_MCP_URL=http://localhost:3001

# TTS — use kokoro locally, switch to elevenlabs for voice tuning days
TTS_PROVIDER=kokoro
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Brave Search
BRAVE_API_KEY=

# Langfuse — omit both keys to disable tracing in dev
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
